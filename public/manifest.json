{
  "manifest_version": 3,
  "name": "XYTdownloader",
  "version": "1.0.0",
  "description": "Download media from X and YouTube",
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.youtube.com/*",
    "https://api.vxtwitter.com/*",
    "https://api.cobalt.tools/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": [
        "content/twitter.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content/youtube.js"
      ],
      "run_at": "document_end"
    }
  ]
}
