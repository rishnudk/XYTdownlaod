{
  "manifest_version": 3,
  "name": "XYTdownloader",
  "version": "1.0.0",
  "description": "Download media from X and YouTube",
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://dribbble.com/*",
    "https://*.dribbble.com/*",
    "https://www.pinterest.com/*",
    "https://pinterest.com/*",
    "https://i.pinimg.com/*",
    "https://www.youtube.com/*",
    "https://api.vxtwitter.com/*",
    "https://api.cobalt.tools/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": [
        "content/twitter.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content/youtube.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://dribbble.com/*"
      ],
      "js": [
        "content/dribbble.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.pinterest.com/*",
        "https://pinterest.com/*"
      ],
      "js": [
        "content/pinterest.js"
      ],
      "run_at": "document_end"
    }
  ]
}
